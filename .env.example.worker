# Worker runtime environment.
# Copy this file to .env.worker for the background worker process/container.

# Primary PostgreSQL database. Must match the web process database.
DATABASE_URL="postgresql://user:password@host:5432/mail"

# Optional database pool size for the worker process.
PG_POOL_MAX="5"

# Only for PostgreSQL servers using a private/self-signed certificate.
PG_TLS_REJECT_UNAUTHORIZED="true"

# Must match the web process when settings secrets are encrypted.
# Must match the web process. Required for OpenPGP private keys.
MAIL_SECRET_KEY=""

# Optional incoming-mail importance classification.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
# Set to "false" to disable automatic classification.
OPENAI_IMPORTANCE_CLASSIFICATION="true"

# Must match the web process. Supports exact IDs and wildcard suffixes such as *.google.com.
MAIL_AUTH_TRUSTED_AUTHSERV_IDS=""

# Demo mode disables the worker because demo data is in-memory in the web process.
DEMO_MODE="false"

# IMAP sync configuration. These values are used when mail settings are not stored in the DB.
IMAP_HOST=""
IMAP_PORT="993"
IMAP_SECURE="true"
# Disables certificate verification for this IMAP server. Leave false unless required.
IMAP_ALLOW_INVALID_CERTIFICATE="false"
IMAP_USER=""
IMAP_PASSWORD=""
IMAP_MAILBOX="INBOX"
IMAP_POLL_SECONDS="15"

# SMTP send configuration. These values are used when mail settings are not stored in the DB.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
# Disables certificate verification for this SMTP server. Leave false unless required.
SMTP_ALLOW_INVALID_CERTIFICATE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""
