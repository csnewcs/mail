{
  "name": "Mail",
  "short_name": "Mail",
  "description": "Personal mail client",
  "id": "/",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone"],
  "orientation": "portrait",
  "background_color": "#0d0d10",
  "theme_color": "#0d0d10",
  "protocol_handlers": [
    {
      "protocol": "mailto",
      "url": "/inbox?mailto=%s"
    }
  ],
  "share_target": {
    "action": "/inbox",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "share-title",
      "text": "share-text",
      "url": "share-url"
    }
  },
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-maskable-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icon-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/pwa-wide.png",
      "sizes": "1440x900",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Mail inbox on desktop"
    },
    {
      "src": "/pwa-mobile.png",
      "sizes": "390x844",
      "type": "image/png",
      "label": "Mail inbox on mobile"
    }
  ]
}
