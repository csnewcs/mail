# Web runtime environment.
# Copy this file to .env for the SvelteKit web process.

# Primary PostgreSQL database. The web process and worker must share the same database.
DATABASE_URL="postgresql://user:password@host:5432/mail"

# Optional database pool size for the web process.
PG_POOL_MAX="10"

# Only for PostgreSQL servers using a private/self-signed certificate.
# This setting is scoped to PostgreSQL and never affects OAuth/OIDC HTTPS requests.
PG_TLS_REJECT_UNAUTHORIZED="true"

# Public origin users connect to. This must match the request Origin header.
# Example: https://mail.example.com
ORIGIN="http://localhost:3000"

# Set a finite value to impose a request-body limit. Composer attachments are unlimited by default.
BODY_SIZE_LIMIT="Infinity"

# Better Auth secret. Use a high-entropy value with at least 32 characters in production.
# https://better-auth.com/docs/installation#set-environment-variables
BETTER_AUTH_SECRET="change-me-to-a-long-random-secret"

# Encryption key for private OpenPGP keys, mail passwords, and OAuth/OIDC client secrets.
# Use the same high-entropy value in the web and worker environments. Existing
# plaintext database passwords stay readable without this key and migrate to
# encrypted enc:v1 values after the key is configured. OpenPGP private-key
# generation and import are disabled until this value is configured.
MAIL_SECRET_KEY=""

# Demo mode disables live database/mail/auth requirements.
DEMO_MODE="false"

# Optional authentication providers. These can also be configured in the setup/settings UI.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# Manual OpenID Connect configuration (no discovery document required).
OIDC_ISSUER=""
OIDC_AUTHORIZATION_URL=""
OIDC_TOKEN_URL=""
OIDC_USER_INFO_URL=""
OIDC_CLIENT_ID=""
OIDC_CLIENT_SECRET=""

# Deprecated compatibility fallback for existing installations only.
OIDC_DISCOVERY_URL=""

# Optional AI features. When configured, incoming mail is also classified for importance.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
# Set to "false" to keep AI features available without sending incoming mail for classification.
OPENAI_IMPORTANCE_CLASSIFICATION="true"

# Must match the worker. Supports exact IDs and wildcard suffixes such as *.google.com.
MAIL_AUTH_TRUSTED_AUTHSERV_IDS=""

# Optional mail configuration fallback for the web settings UI.
# The background worker uses .env.example.worker. Prefer configuring IMAP/SMTP in the UI
# so both processes read the same values from the database.
# IMAP_HOST=""
# IMAP_PORT="993"
# IMAP_SECURE="true"
# Only enable this for a trusted server with a self-signed/private certificate.
# IMAP_ALLOW_INVALID_CERTIFICATE="false"
# IMAP_USER=""
# IMAP_PASSWORD=""
# IMAP_MAILBOX="INBOX"
# IMAP_POLL_SECONDS="15"
# Public TCP proxy for the primary IMAP configuration. Docker Compose enables port 993.
# IMAP_PUBLIC_PORT="993"
# IMAP_PUBLIC_CONFIG_ID="primary"
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_SECURE="false"
# Only enable this for a trusted server with a self-signed/private certificate.
# SMTP_ALLOW_INVALID_CERTIFICATE="false"
# SMTP_USER=""
# SMTP_PASSWORD=""
# SMTP_FROM=""
